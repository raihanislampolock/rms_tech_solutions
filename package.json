{
  "name": "rms-tech-solutions",
  "version": "1.0.0",
  "description": "Application for rms tech solutions",
  "main": "build/app.js",
  "scripts": {
    "start": "npm run serve",
    "build": "npm run build-sass && npm run build-ts && npm run lint && npm run copy-static-assets",
    "build-sass": "sass src/public/dist/css/AdminLTE.min.css build/public/dist/css/AdminLTE.min.css",
    "copy-static-assets": "ts-node copyStaticAssets.ts",
    "serve": "node build/app.js",
    "watch-node": "nodemon build/app.js",
    "watch": "concurrently -k -p \"[{name}]\" -n \"Sass,TypeScript,Node\" -c \"yellow.bold,cyan.bold,green.bold\" \"npm run watch-sass\" \"npm run watch-ts\" \"npm run watch-node\"",
    "watch-debug": "concurrently -k -p \"[{name}]\" -n \"Sass,TypeScript,Node\" -c \"yellow.bold,cyan.bold,green.bold\" \"npm run watch-sass\" \"npm run watch-ts\" \"npm run serve-debug\"",
    "test": "jest --forceExit --coverage --verbose",
    "watch-test": "npm run test -- --watchAll",
    "build-ts": "tsc",
    "watch-ts": "tsc -w",
    "watch-sass": "sass -w src/public/dist/css/AdminLTE.min.css build/public/dist/css/AdminLTE.min.css",
    "lint": "tslint -c tslint.json -p tsconfig.json --fix",
    "debug": "npm run build && npm run watch-debug",
    "serve-debug": "nodemon --inspect build/app.js",
    "start-production": "forever start build/app.js",
    "stop-production": "forever stop build/app.js"
  },
  "repository": {
    "type": "git",
    "url": "#"
  },
  "author": "MD NOMAN JUWEL",
  "license": "UNLICENSED",
  "homepage": "",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.964.0",
    "@aws-sdk/lib-storage": "^3.964.0",
    "@fortawesome/fontawesome-free": "^7.0.1",
    "@types/cors": "^2.8.13",
    "@types/formidable": "^2.0.5",
    "@types/move-file": "^1.1.0",
    "@types/multiparty": "^0.0.33",
    "@types/oracledb": "^6.5.2",
    "aws-sdk": "^1.18.0",
    "axios": "^1.15.0",
    "bcrypt": "^6.0.0",
    "bluebird": "^3.7.2",
    "body-parser": "^1.20.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.5",
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "express": "^4.22.1",
    "express-session": "^1.18.1",
    "formidable": "^2.1.1",
    "fs": "0.0.1-security",
    "generate-password": "^1.5.1",
    "html-pdf": "^1.5.0",
    "jsonwebtoken": "^9.0.3",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.0",
    "multer": "^2.1.1",
    "multiparty": "^4.2.3",
    "node-cron": "^2.0.3",
    "nodemailer": "^8.0.5",
    "oracledb": "^6.9.0",
    "pdf-lib": "^1.17.1",
    "pg": "^8.13.0",
    "phantomjs-prebuilt": "^2.1.16",
    "process": "^0.11.10",
    "pug": "^3.0.0",
    "puppeteer": "^23.5.3",
