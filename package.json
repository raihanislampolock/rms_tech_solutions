    "@types/express": "^4.17.16",
    "@types/express-session": "^1.18.0",
    "@types/generate-password": "^1.5.0",
    "@types/jsonwebtoken": "^8.5.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^14.18.36",
    "@types/node-cron": "^2.0.3",
    "@types/nodemailer": "^6.4.7",
    "@types/path-to-regexp": "^1.0.29",
    "@types/pg": "^8.11.10",
    "@types/pug": "^2.0.4",
    "@types/puppeteer": "^5.4.7",
    "@types/shelljs": "^0.8.8",
