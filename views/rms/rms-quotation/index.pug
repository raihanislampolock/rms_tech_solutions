block script
  link(rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/daterangepicker/daterangepicker.css")
  script(type="text/javascript" src="https://cdn.jsdelivr.net/momentjs/latest/moment.min.js")
  script(type="text/javascript" src="https://cdn.jsdelivr.net/npm/daterangepicker/daterangepicker.min.js")
  script(src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js")
  
  script.
    document.addEventListener('DOMContentLoaded', function() {
      const tableBody = document.getElementById('quotationTableBody');
      const paginationContainer = document.getElementById('paginationContainer');
      let search = document.getElementById('search');
      const searchBtn = document.getElementById('searchBtn');
      const limitSelect = document.getElementById('limitSelect');
      const dateRangeDisplay = document.querySelector('#date-range-display');
      const dateRangeInput = document.getElementById('date-range-input');

      const updateMargin = () => {
        if (dateRangeDisplay.textContent.trim() === "Select date range") {
        dateRangeDisplay.style.marginRight = "70px";
        } else {
        dateRangeDisplay.style.marginRight = "0";
        }
      };

        // Initial check
        updateMargin();

        // Observe changes in text content
        const observer = new MutationObserver(updateMargin);
        observer.observe(dateRangeDisplay, { childList: true, characterData: true, subtree: true });

      let currentPage = 1;
      let currentSearch = '';
      let limit = limitSelect.value;
      let dateRange = '';
      const selectedRows = new Set();
      const selectedData = [];

      async function fetchQuotation(page = 1, search = '', dateRange='', limit = 10) {
        tableBody.innerHTML = `<tr><td colspan="18" class="text-center"><i class="fa fa-spinner fa-spin" style="font-size: 24px; color: #8A2061;"></i></td></tr>`;
        try {
          const response = await fetch(`/api/rms/rms-quotation/all?page=${page}&search=${search}&limit=${limit}`);
          const data = await response.json();

          if (data?.data?.length > 0) {
            const grouped = {};

            data.data.forEach(row => {
              if (!grouped[row.id]) {
                grouped[row.id] = {
                  id: row.id,
                  refNumber: row.refNumber,
                  companyName: row.companyName,
                  companyEmail: row.companyEmail,
                  subject: row.subject,
                  discriptions: row.discriptions,
                  createdBy: row.createdBy,
                  updatedBy: row.updatedBy,
                  created_at: row.created_at,
                  updated_at: row.updated_at,
                  items: []
                };
              }

              grouped[row.id].items.push({
                itemName: row.itemName,
                itemType: row.itemType,
                itemModel: row.itemModel,
                itemConfigurations: row.itemConfigurations,
                itemPrice: row.itemPrice,
                rmsPrice: row.rmsPrice,
                quarterly: row.quarterly,
                totalItemPrice: row.totalItemPrice,
                totalRmsPrice: row.totalRmsPrice,
                files: row.files
              });
            });

            // =========================
            // ✅ RENDER GROUPED UI
            // =========================
            tableBody.innerHTML = Object.values(grouped).map(q => {
              const totalQty = q.items.reduce((sum, i) => sum + (Number(i.quarterly) || 0), 0);
              const itemPrice = q.items.reduce((sum, i) => sum + (Number(i.itemPrice) || 0), 0);
              const sellPrice = q.items.reduce((sum, i) => sum + (Number(i.rmsPrice) || 0), 0);
              const totalBuy = q.items.reduce((sum, i) => sum + (Number(i.totalItemPrice) || 0), 0);
              const totalSell = q.items.reduce((sum, i) => sum + (Number(i.totalRmsPrice) || 0), 0);

              const format = (num) => Number(num || 0).toLocaleString();

              return `

              <!-- MAIN QUOTATION ROW -->
              <tr style="background:#f5f5f5;font-weight:bold;">
                <td>
                  <a href="#"
                     class="editQuotation fa fa-edit"
                     data-quotation-id="${q.id}"
                     data-toggle="modal"
                     data-target="#add-edit-quotation-modal">
                  </a>
                </td>
                <td>
                  <a href="/api/rms/rms-quotation/generate-pdf/${q.id}"
                     class="fa fa-file-pdf-o fa-2x"
                     target="_blank"
                     title="Generate PDF">
                  </a>
                </td>
                <td>
                  <a href="#"
                     class="sendQuotationEmail fa fa-envelope fa-2x"
                     data-quotation-id="${q.id}"
                     data-company-email="${q.companyEmail}"
                     data-company-name="${q.companyName}"
                     title="Send via Email">
                  </a>
                </td>

                <td>${q.refNumber ?? ''}</td>
                <td>${q.companyName ?? ''}</td>
                <td>${q.companyEmail ?? ''}</td>

                <!-- View Items column -->
                <td>
                  <button class="btn btn-sm btn-info toggleItems" data-id="${q.id}">
                    View Items (${q.items.length})
                  </button>
                </td>

                <td>${q.createdBy ?? ''}</td>
                <td>${q.updatedBy ?? ''}</td>
                <td>${q.created_at ?? ''}</td>
                <td>${q.updated_at ?? ''}</td>
              </tr>

              <!-- ITEMS ROW -->
              <tr id="items-${q.id}" style="display:none;">
                <td colspan="21">
                  <table class="table table-bordered">
                    <thead style="background:#580db4;color:white;">
                      <tr>
                        <th>Item</th>
                        <th>Type</th>
                        <th>Model</th>
                        <th>Spec</th>
                        <th>Qty</th>
                        <th>Buy</th>
                        <th>Sell</th>
                        <th>Total Buy</th>
                        <th>Total Sell</th>
                      </tr>
                    </thead>
                    <tbody>
                      ${q.items.map(i => `
                        <tr>
                          <td>${i.itemName ?? ''}</td>
                          <td>${i.itemType ?? ''}</td>
                          <td>${i.itemModel ?? ''}</td>
                          <td>${i.itemConfigurations ?? ''}</td>
                          <td>${i.quarterly ?? ''}</td>
                          <td>${i.itemPrice ?? ''}</td>
                          <td>${i.rmsPrice ?? ''}</td>
                          <td>${i.totalItemPrice ?? ''}</td>
                          <td>${i.totalRmsPrice ?? ''}</td>
                        </tr>
                      `).join('')}
                    <!-- ✅ TOTAL ROW -->
                            <tr style="background:#e8f5e9; font-weight:bold;">
                              <td colspan="4" style="text-align:right;">TOTAL</td>
                              <td>${format(totalQty)}</td>
                              <td>${format(itemPrice)}</td>
                              <td>${format(sellPrice)}</td>
                              <td>${format(totalBuy)}</td>
                              <td>${format(totalSell)}</td>
                            </tr>
                          </tbody>
                        </table>
                      </td>
                    </tr>
            `}).join('');

            selectedRows.forEach((id) => {
              const row = tableBody.querySelector(`[data-id="${id}"]`);
              if (row) row.classList.add('selected-row');
          });

          const totalRecords = data.total;
          const startRecord = (currentPage - 1) * limit + 1;
          const endRecord = Math.min(currentPage * limit, totalRecords);

          document.querySelector('#title-filter').textContent = `Showing ${startRecord} to ${endRecord} of ${totalRecords} entries`;

          } else {
            tableBody.innerHTML = `<tr><td colspan="18" class="text-center">No data found</td></tr>`;
            document.querySelector('#title-filter').textContent = 'No entries to display';
            return;
          }

          // Generate pagination buttons
          const totalPages = Math.ceil(data.totalRecords / limit);
          renderPagination(totalPages, page);

        } catch (error) {
          console.error('Error fetching reports:', error);
          tableBody.innerHTML = `<tr><td colspan="18" class="text-center">Error loading data</td></tr>`;
          document.querySelector('#title-filter').textContent = 'Error loading entries';
        }
      }

      function renderPagination(totalPages, currentPage) {
        paginationContainer.innerHTML = ""

        const maxVisiblePages = 5
        const firstPages = 2
        const lastPages = 2

        // Helper function to create pagination link
        const createPageLink = (page, isActive = false) => {
          const pageItem = document.createElement("li")
          if (isActive) pageItem.classList.add("active")
          pageItem.innerHTML = `<a href="#" class="pagination-link" data-page="${page}">${page}</a>`
          paginationContainer.appendChild(pageItem)
        }

        // Show "Previous" button if not on first page
        if (currentPage > 1) {
          const prevItem = document.createElement("li")
          prevItem.innerHTML = `<a href="#" class="pagination-link" data-page="${currentPage - 1}">« Previous</a>`
          paginationContainer.appendChild(prevItem)
        }

        // For small number of pages, show all pages without ellipsis
        if (totalPages <= maxVisiblePages) {
          for (let i = 1; i <= totalPages; i++) {
            createPageLink(i, i === currentPage)
          }
        } else {
          // Show first page
          createPageLink(1, currentPage === 1)

          // Calculate range of pages to show around current page
          let rangeStart = Math.max(2, currentPage - Math.floor(maxVisiblePages / 2))
          const rangeEnd = Math.min(totalPages - 1, rangeStart + maxVisiblePages - 3)

          // Adjust range if current page is near the end
          if (rangeEnd === totalPages - 1) {
            rangeStart = Math.max(2, rangeEnd - maxVisiblePages + 3)
          }

          // Show ellipsis after first page if needed
          if (rangeStart > 2) {
            paginationContainer.innerHTML += `<li><span>...</span></li>`
          }

          // Show pages in range
          for (let i = rangeStart; i <= rangeEnd; i++) {
            createPageLink(i, i === currentPage)
          }

          // Show ellipsis before last page if needed
          if (rangeEnd < totalPages - 1) {
            paginationContainer.innerHTML += `<li><span>...</span></li>`
          }

          // Show last page if not already shown
          if (totalPages > 1) {
            createPageLink(totalPages, currentPage === totalPages)
          }
        }

        // Show "Next" button if not on last page
        if (currentPage < totalPages) {
          const nextItem = document.createElement("li")
          nextItem.innerHTML = `<a href="#" class="pagination-link" data-page="${currentPage + 1}">Next »</a>`
          paginationContainer.appendChild(nextItem)
        }
      }

       // Update page and fetch data
      function updatePage(page) {
        let currentSearch = search.value;
        dateRange = dateRangeInput.value;
        currentPage = page;
        fetchQuotation(currentPage, currentSearch, dateRange, limit);
      }

      // Event listener for pagination links
      paginationContainer.addEventListener('click', function(event) {
        if (event.target.classList.contains('pagination-link')) {
          event.preventDefault();
          const page = parseInt(event.target.getAttribute('data-page'), 10);
          if (!isNaN(page)) {
            updatePage(page);
          }
        }
      });

      // Search and limit event listeners
      searchBtn.addEventListener('click', () => {
        selectedRows.clear();
        selectedData.length = 0;
        currentSearch = search.value;
        dateRange = dateRangeInput.value;
        fetchQuotation(1, currentSearch, dateRange, limit);
      });
      
      limitSelect.addEventListener('change', () => {
        limit = limitSelect.value;
        currentSearch = search.value;
        dateRange = dateRangeInput.value;
        currentPage = 1;
        fetchQuotation(currentPage, currentSearch, dateRange, limit);
      });

      function updateSelectedData(rowId, email, mrno, patientName) {
          if (add) {
            selectedData.push({ id: rowId, email, mrno, patientName });
          } else {
            const index = selectedData.findIndex(item => item.id === rowId);
            if (index !== -1) selectedData.splice(index, 1);
          } 
      }

      const today = new Date();
      const yesterday = new Date(today);
      yesterday.setDate(today.getDate() - 1);
      
      // Initialize the daterangepicker
      $('#daterange-btn').daterangepicker({
        startDate: yesterday,
        endDate: today,
        ranges: {
          'Today': [moment(), moment()],
          'Yesterday': [moment().subtract(1, 'days'), moment().subtract(1, 'days')],
          'Last 7 Days': [moment().subtract(6, 'days'), moment()],
          'Last 30 Days': [moment().subtract(29, 'days'), moment()],
          'This Month': [moment().startOf('month'), moment().endOf('month')],
          'Last Month': [moment().subtract(1, 'month').startOf('month'), moment().subtract(1, 'month').endOf('month')]
        },
        locale: {
          format: 'MMMM DD, YYYY'
        }
      }, function(start, end, label) {
        const startDate = start.format('MMMM DD, YYYY');
        const endDate = end.format('MMMM DD, YYYY');
        
        dateRangeDisplay.innerText = `${startDate} - ${endDate}`;
        dateRangeInput.value = `${startDate} - ${endDate}`;
      });

      const initialStart = moment(yesterday).format('MMMM DD, YYYY');
      const initialEnd = moment(today).format('MMMM DD, YYYY');
      dateRangeDisplay.innerText = `${initialStart} - ${initialEnd}`;
      dateRangeInput.value = `${initialStart} - ${initialEnd}`;

      $('.btn-download').on('click', function () {
        const dateRangeDisplay = document.querySelector('#date-range-display');
        const $downloadBtn = $(".btn-download");
        const originalText = $downloadBtn.html();
        let dateRange = dateRangeDisplay.textContent.trim();

        if (!dateRange) {
            alert("No date range selected!");
            return;
        }

        $downloadBtn.prop("disabled", true).html(`<i class="fas fa-spinner fa-spin"></i> Downloading...`);

        $.ajax({
          url: `/api/callcenter/service-status/export-excel?`, // Move dateRange to query param
          method: "GET", // ✅ MUST match controller
          xhrFields: { responseType: "blob" },
          success: function (blob, status, xhr) {
              const contentDisposition = xhr.getResponseHeader("Content-Disposition");
              let filename = "X_Ray_Tracker.xlsx";
              if (contentDisposition) {
                  const match = contentDisposition.match(/filename="(.+)"/);
                  if (match && match.length > 1) {
                      filename = match[1];
                  }
              }

              const blobUrl = window.URL.createObjectURL(blob);
              const a = document.createElement("a");
              a.href = blobUrl;
              a.download = filename;
              document.body.appendChild(a);
              a.click();
              window.URL.revokeObjectURL(blobUrl);
              document.body.removeChild(a);
          },
          error: function (xhr, status, err) {
              console.error("XHR:", xhr);
              console.error("Status:", status);
              console.error("Error:", err);
              alert("Failed to download. Please try again.");
          },
          complete: function () {
              // Restore button state
              $downloadBtn.prop("disabled", false).html(originalText);
          }
      });

    });      

      fetchQuotation(currentPage, currentSearch, dateRangeInput.value, limit);
    });

    document.addEventListener('DOMContentLoaded', function () {

        let cart = [];
        let editMode = false;
        let editId = null;

        document.addEventListener('click', function (e) {

          const btn = e.target.closest('[data-quotation-id]');
          if (!btn) return;

          e.preventDefault();

          const id = Number(btn.getAttribute('data-quotation-id'));

          if (!id || isNaN(id)) {
              console.error("Invalid quotation id:", btn);
              return;
          }

          console.log("CLICKED ID:", id); // 👈 MUST SHOW NUMBER

          loadQuotation(id);
        });

        // ========================
        // 📧 SEND EMAIL WITH PDF
        // ========================
        document.addEventListener('click', function (e) {
          if (!e.target.classList.contains('sendQuotationEmail')) return;

          e.preventDefault();

          const id = Number(e.target.getAttribute('data-quotation-id'));
          const email = e.target.getAttribute('data-company-email');
          const companyName = e.target.getAttribute('data-company-name');

          if (!id || !email) {
              alert('❌ Email not found for this quotation');
              return;
          }

          // Confirm before sending
          if (!confirm(`Send quotation to ${email}?`)) {
              return;
          }

          // Show loading state
          const originalClass = e.target.className;
          e.target.className = 'fa fa-spinner fa-spin fa-2x';
          e.target.style.cursor = 'not-allowed';

          // Send email via API
          fetch(`/api/rms/rms-quotation/send-email/${id}`, {
              method: 'POST',
              headers: {
                  'Content-Type': 'application/json'
              }
          })
          .then(response => response.json())
          .then(data => {
              e.target.className = originalClass;
              e.target.style.cursor = 'pointer';

              if (data.status) {
                  alert('✅ ' + data.message);
              } else {
                  alert('❌ ' + (data.message || 'Failed to send email'));
              }
          })
          .catch(error => {
              e.target.className = originalClass;
              e.target.style.cursor = 'pointer';
              console.error('Error:', error);
              alert('❌ Error sending email: ' + error.message);
          });
        });

        const itemSelect = document.getElementById('itemSelect');
        const itemPrice = document.getElementById('itemPrice');
        const itemModel = document.getElementById('itemModel');
        const itemType = document.getElementById('itemType');
        const itemConfigurations = document.getElementById('itemConfigurations');
        const rmsPrice = document.getElementById('rmsPrice');
        const quarterly = document.getElementById('quarterly');
        const refInput = document.getElementById('refNumber');

        function resetForm() {
            editMode = false;
            editId = null;
            cart = [];

            document.getElementById('quotation-form').reset();
            renderCart();
        }

        // =========================
        // MODAL OPEN
        // =========================
        const modal = $('#add-edit-quotation-modal');
        modal.on('shown.bs.modal', async function () {

            // ONLY reset when NOT editing
            if (!editMode) {
                resetForm();

                try {
                    const res = await fetch(`/api/rms/rms-quotation/generate-ref?companyName=TEMP`);
                    const data = await res.json();

                    if (data.status && data.refNumber) {
                        refInput.value = data.refNumber;
                    } else {
                        refInput.value = "";
                    }

                } catch (err) {
                    console.error("REF ERROR:", err);
                }
            }
        });


        // =========================
        // 1️⃣ ITEM CHANGE
        // =========================
        itemSelect.addEventListener('change', function () {
            const selectedOption = this.options[this.selectedIndex];

            if (!selectedOption || !selectedOption.value) {
                clearItemFields();
                return;
            }

            itemPrice.value = selectedOption.dataset.price || '';
            itemModel.value = selectedOption.dataset.model || '';
            itemType.value = selectedOption.dataset.type || '';
            itemConfigurations.value = selectedOption.dataset.config || '';
            quarterly.value = selectedOption.dataset.quarterly || '';
        });

        function clearItemFields() {
            itemPrice.value = '';
            itemModel.value = '';
            itemType.value = '';
            itemConfigurations.value = '';
            quarterly.value = '';
        }

        // =========================
        // 2️⃣ ADD ITEM
        // =========================
        document.getElementById('addItem').addEventListener('click', function () {
        
            const selectedOption = itemSelect.options[itemSelect.selectedIndex];
            const itemId = itemSelect.value;

            if (!itemId) return alert('Please select an item first!');

            if (cart.find(i => i.itemId == itemId)) {
                return alert('Item already added!');
            }

            const item = {
                itemId: itemId,
                itemName: selectedOption.dataset.name || selectedOption.text,
                itemModel: selectedOption.dataset.model || '',
                itemType: selectedOption.dataset.type || '',
                itemConfigurations: selectedOption.dataset.config || '',
                itemPrice: parseFloat(selectedOption.dataset.price) || 0,
                rmsPrice: parseFloat(rmsPrice.value) || 0,
                quarterly: parseFloat(quarterly.value || 1) || 1
            };

            cart.push(item);
            renderCart();

            itemSelect.value = '';
            clearItemFields();
            rmsPrice.value = '';
        });

        // =========================
        // 3️⃣ REMOVE ITEM
        // =========================
        document.addEventListener('click', function (e) {
            if (e.target.closest('.removeItem')) {
                const index = e.target.closest('.removeItem').dataset.index;
                cart.splice(index, 1);
                renderCart();
            }
        });

        // =========================
        // 4️⃣ UPDATE RMS PRICE
        // =========================
        document.addEventListener('input', function (e) {
            if (e.target.classList.contains('rms-price')) {
                const index = e.target.dataset.index;
                let val = parseFloat(e.target.value) || 0;
                if (val < 0) val = 0;
                cart[index].rmsPrice = val;
            }
        });

        // =========================
        // 5️⃣ RENDER CART
        // =========================
        function renderCart() {
            const tbody = document.querySelector('#itemTable tbody');
            tbody.innerHTML = '';

            if (!cart.length) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="10" class="text-center">No item added yet.</td>
                    </tr>
                `;
                return;
            }

            cart.forEach((item, index) => {
                const totalItemPrice = item.itemPrice * item.quarterly;
                const totalRmsPrice = item.rmsPrice * item.quarterly;
                tbody.innerHTML += `
                    <tr>
                        <td>${item.itemName}</td>
                        <td>${item.itemType}</td>
                        <td>${item.itemModel}</td>
                        <td>${item.itemConfigurations}</td>
                        <td>${item.quarterly}</td>
                        <td class="text-right">${item.itemPrice.toFixed(2)}</td>
                        <td>
                            <input type="number"
                                   class="form-control rms-price"
                                   value="${item.rmsPrice}"
                                   data-index="${index}"
                                   min="0">
                        </td>
                        <td class="text-right">${totalItemPrice.toFixed(2)}</td>
                        <td class="text-right">${totalRmsPrice.toFixed(2)}</td>
                        <td class="text-center">
                            <button type="button"
                                    class="btn btn-danger btn-sm removeItem"
                                    data-index="${index}">
                                <i class="fa fa-trash"></i>
                            </button>
                        </td>
                    </tr>
                `;
            });
        }

        // =========================
        // 6️⃣ LOAD EDIT DATA (NEW)
        // =========================
        async function loadQuotation(id) {
            try {
                const res = await fetch(`/api/rms/rms-quotation/edit/${id}`);
                const result = await res.json();
        
                if (!result.status) return;
        
                const data = result.data;
        
                editMode = true;
                editId = id;
        
                document.getElementById('refNumber').value = data.refNumber || '';
                document.getElementById('companyName').value = data.companyName || '';
                document.getElementById('companyEmail').value = data.companyEmail || '';
                document.getElementById('subject').value = data.subject || '';
                document.getElementById('discriptions').value = data.discriptions || '';
        
                cart = (data.items || []).map(i => ({
                    itemId: i.itemId,
                    itemName: i.itemName || '',
                    itemType: i.itemType || '',
                    itemModel: i.itemModel || '',
                    itemConfigurations: i.itemConfigurations || '',
                    itemPrice: Number(i.itemPrice) || 0,
                    rmsPrice: Number(i.rmsPrice) || 0,
                    quarterly: Number(i.quarterly) || 1
                }));
        
                renderCart();
        
            } catch (err) {
                console.error("Edit load failed:", err);
            }
        }

        // =========================
        // 7️⃣ SAVE / UPDATE
        // =========================
        document.getElementById('saveQuotation').addEventListener('click', async function () {
        
            if (!cart.length) {
                return alert('No items added!');
            }

            const payload = {
                refNumber: document.getElementById('refNumber').value,
                companyName: document.getElementById('companyName').value,
                companyEmail: document.getElementById('companyEmail').value,
                subject: document.getElementById('subject').value,
                discriptions: document.getElementById('discriptions').value,
                items: cart
            };

            let url = '/rms/rms-quotation/create';
            let method = 'POST';

            if (editMode) {
                url = `/api/rms/rms-quotation/update/${editId}`;
                method = 'PUT';
            }

            try {
                const res = await fetch(url, {
                    method,
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(payload)
                });

                const result = await res.json();

                if (result.status) {
                    swal({
                        title: editMode ? "Updated successfully" : "Created successfully",
                        text: result.message || "",
                        icon: "success",
                        button: "OK"
                    }).then(() => {
                        window.location.reload();
                    });
                } else {
                    swal("Error", result.message || "Failed to save quotation", "error");
                }

            } catch (err) {
                console.error(err);
                alert("Request failed");
            }
        });

        // =========================
        // AUTO EDIT MODE (if URL has id)
        // =========================
        const urlParts = window.location.pathname.split('/');
        const possibleId = urlParts[urlParts.length - 1];

        if (!isNaN(possibleId)) {
            loadQuotation(possibleId);
        }

    });

    document.addEventListener('input', function (e) {
        if (e.target.classList.contains('rms-price')) {
            const index = e.target.dataset.index;
            let val = parseFloat(e.target.value) || 0;

            if (val < 0) val = 0;

            cart[index].rmsPrice = val;

            renderCart(); // 🔥 re-render to update totals
        }
    });

    document.addEventListener('click', function(e) {
      if (e.target.classList.contains('toggleItems')) {
        const id = e.target.dataset.id;
        const row = document.getElementById(`items-${id}`);

        if (row.style.display === 'none') {
          row.style.display = 'table-row';
        } else {
          row.style.display = 'none';
        }
      }
    });