extends ../../layout
block style
  link(rel='stylesheet' href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css')
  link(rel='stylesheet' href='https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css')
  style.
    .selected-row {
      background-color: #580db4 !important;
      color: white !important;
    }

    .form-group {
      position: relative;
      margin-bottom: 7px;
    }

    .form-group input,
    .form-group textarea {
        width: 100%;
        padding: 1rem 1rem 0.3rem;
        border: 1px solid #ccc;
        border-radius: 4px;
        background: none;
        font-size: 1rem;
        outline: none;
        transition: border-color 0.3s, box-shadow 0.3s, padding-top 0.3s;
    }

    .form-group input:focus,
    .form-group textarea:focus {
        border-color: #580db4;
        box-shadow: 0 0 4px rgba(15, 55, 186, 0.6);
    }

    .form-group label {
        position: absolute;
        top: 0.7rem;
        left: 1rem;
        transform: translateY(0);
        font-size: 1rem;
        color: #aaa;
        pointer-events: none;
        transition: all 0.3s;
        background-color: white;
        padding: 0 5px;
    }

    .form-group input:focus + label,
    .form-group input:not(:placeholder-shown) + label,
    .form-group textarea:focus + label,
    .form-group textarea:not(:placeholder-shown) + label {
        top: -0.6rem; /* Move the label to the top padding */
        font-size: 0.8rem;
        color: #580db4;
        padding: 0 5px; /* Keeps label inside */
    }

    .form-group-row {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .form-check {
        margin-top: 1rem;
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .form-check-input {
        width: 2rem;
        height: 2rem;
        margin: 0;
        cursor: pointer;
        accent-color: #580db4;
    }

    .form-check-label {
        font-size: 1rem;
        color: #555;
        cursor: pointer;
        margin-left: 0.1rem;
        margin-top: 0.5rem;
    }

    #add-edit-appointment-modal .modal-dialog {
        max-width: 80%;
        width: auto;
    }

    #show-appointment-modal .modal-dialog {
        max-width: 90%;
        width: auto;
    }

    .btn-group .btn-small {
        padding: 2px 8px;
        font-size: 12px;
        line-height: 1.5;
        border-radius: 3px;
        background-color: #580db4;
        color: white;
        border: none;
    }
    .btn-group .btn-small:hover,
    .btn-group .btn-small:focus {
        background-color: #580db4;
    }
    .btn-group .dropdown-menu {
        font-size: 12px;
        min-width: 100px;
    }
    .caret {
        margin-left: 2px;
    }

    /* Ensure the container has limited height and overflow */
    .table-responsive {
      max-height: 400px; /* Adjust height as needed */
      overflow-y: auto;
      position: relative;
    }

    /* Fix the table header */
    .table-responsive table thead {
      position: sticky;
      top: 0;
      background-color: #fff; /* Match table background */
      z-index: 2;
      box-shadow: 0 2px 2px rgba(0, 0, 0, 0.1); /* Optional shadow for better visibility */
    }

    #tableHead {
      background-color: #580db4;
      color: white;
    }

    .green {
      background-color: #00a65a !important;
    }
    .cancelled {
      background-color: #dd4b39 !important;
    }


    /* Reset modal styles */
    #multi-appointment-modal .modal {
        position: fixed;
        top: 0;
        right: 0;
        bottom: 0;
        left: 0;
        z-index: 1050;
        display: none;
        outline: 0;
        overflow: hidden;
    }

    /* Prevent body scrolling */
    body.modal-open {
        overflow: hidden;
        padding-right: 0 !important;
    }

    /* Modal dialog styles */
    #multi-appointment-modal .modal-dialog {
        position: relative;
        width: auto;
        margin: 0;
        max-width: 1000px;
        height: 100%;
        display: flex;
        align-items: stretch;
    }

    /* Modal content styles */
    #multi-appointment-modal .modal-content {
        position: relative;
        display: flex;
        flex-direction: column;
        width: 100%;
        height: 100vh;
        background-color: #fff;
        border: 1px solid rgba(0, 0, 0, 0.2);
        border-radius: 0;
        outline: 0;
    }

    /* Modal header styles - Fixed to have title on left and close button on right */
    #multi-appointment-modal .modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 15px;
        flex-direction: row; /* Ensure correct direction */
    }

     #multi-appointment-modal .modal-header .modal-title {
        margin: 0;
        line-height: 1.5;
        order: 0; /* Ensure title is first */
    }

    #multi-appointment-modal .modal-header .close {
        order: 1; /* Ensure close button is last */
        padding: 1rem;
        margin: -1rem -1rem -1rem auto;
    }

    /* Modal body styles */
    #multi-appointment-modal .modal-body {
        position: relative;
        flex: 1 1 auto;
        padding: 15px;
    }

    /* Scrollable area styles */
    #multi-appointment-modal .scrollable-area {
        height: calc(100vh - 130px); /* Adjust based on header and footer height */
        overflow-y: scroll !important; /* Force scrollbar to always show */
        overflow-x: hidden;
    }

    /* Modal footer styles */
    #multi-appointment-modal .modal-footer {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        padding: 15px;
    }

    /* Custom scrollbar styles */
    #multi-appointment-modal .scrollable-area::-webkit-scrollbar {
        width: 6px;
        display: block;
    }

    #multi-appointment-modal .scrollable-area::-webkit-scrollbar-track {
        background: #f1f1f1;
        border-radius: 10px;
    }

    #multi-appointment-modal .scrollable-area::-webkit-scrollbar-thumb {
        background: #888;
        border-radius: 10px;
    }

    #multi-appointment-modal .scrollable-area::-webkit-scrollbar-thumb:hover {
        background: #555;
    }

    .btn-green {
      background-color: green;
      color: white;
      border: none;
    }
    
    .btn-green:hover {
      background-color: darkgreen;
    }

