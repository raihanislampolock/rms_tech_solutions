block script
  script.
    document.addEventListener('DOMContentLoaded', function() {
      const tableBody = document.getElementById('itemsTableBody');
      if (!tableBody) {
        console.error("Element with id 'itemsTableBody' not found.");
        return;
      }
      const paginationContainer = document.getElementById('paginationContainer');
      const searchStr = document.getElementById('search');
      const searchBtn = document.getElementById('searchBtn');
      const limitSelect = document.getElementById('limitSelect');

      let currentPage = 1;
      let currentSearch = '';
      let limit = limitSelect.value;

      async function fetchItems(page = 1, search = '', limit = 10) {
        tableBody.innerHTML = `<tr><td colspan="12" class="text-center"><i class="fa fa-spinner fa-spin" style="font-size: 24px; color: #8A2061;"></i></td></tr>`;
        try {
          const response = await fetch(`/api/rms/rms-items/all?page=${page}&search=${search}&limit=${limit}`);
          const data = await response.json();
          console.log("API Response:", data);

          if (data?.data?.length > 0) {
            tableBody.innerHTML = data.data.map(items => {
            return `
              <tr style='cursor:pointer' class="table-row">
                <td>
                  <a href="" id='editItems' class="fa fa-edit" data-items-id="${items.id}" style="font-size: 1em;" data-toggle='modal' data-target='#add-edit-items-modal'></a>
                </td>
                <td>${items.itemType}</td>
                <td>${items.itemName}</td>
                <td>${items.manufactureOrigin}</td>
                <td>${items.itemModel}</td>
                <td>${items.itemPrice}</td>
                <td>${items.itemConfigurations}</td>               
                <td>
                  ${
                    items.files
                      ? `<a href="/${items.files}" target="_blank">
                           <img src="/${items.files}" style="width:60px;height:60px;object-fit:cover;border-radius:5px;" />
                         </a>`
                      : 'No File'
                  }
                </td>
                <td>${items.createdBy}</td>
                <td>${items.updatedBy}</td>
                <td>${items.created_at}</td>
                <td>${items.updated_at}</td>
              </tr>
          `;
          }).join('');

          const totalRecords = data.total;
          const startRecord = (currentPage - 1) * limit + 1;
          const endRecord = Math.min(currentPage * limit, totalRecords);

          document.querySelector('#title-filter').textContent = `Showing ${startRecord} to ${endRecord} of ${totalRecords} entries`;

          } else {
            tableBody.innerHTML = `<tr><td colspan="12" class="text-center">No data found</td></tr>`;
            document.querySelector('#title-filter').textContent = 'No entries to display';
            return;
          }          

          // Generate pagination buttons
          const totalPages = Math.ceil(data.total / limit);
          renderPagination(totalPages, currentPage);

        } catch (error) {
          console.error('Error fetching reports:', error);
          tableBody.innerHTML = `<tr><td colspan="12" class="text-center">Error loading data</td></tr>`;
          document.querySelector('#title-filter').textContent = 'Error loading entries';
        }
      }

      function renderPagination(totalPages, currentPage) {
        paginationContainer.innerHTML = ""

        const maxVisiblePages = 5
        const firstPages = 2
        const lastPages = 2

        // Helper function to create pagination link
        const createPageLink = (page, isActive = false) => {
          const pageItem = document.createElement("li")
          if (isActive) pageItem.classList.add("active")
          pageItem.innerHTML = `<a href="#" class="pagination-link" data-page="${page}">${page}</a>`
          paginationContainer.appendChild(pageItem)
        }

        // Show "Previous" button if not on first page
        if (currentPage > 1) {
          const prevItem = document.createElement("li")
          prevItem.innerHTML = `<a href="#" class="pagination-link" data-page="${currentPage - 1}">« Previous</a>`
          paginationContainer.appendChild(prevItem)
        }

        // For small number of pages, show all pages without ellipsis
        if (totalPages <= maxVisiblePages) {
          for (let i = 1; i <= totalPages; i++) {
            createPageLink(i, i === currentPage)
          }
        } else {
          // Show first page
          createPageLink(1, currentPage === 1)

          // Calculate range of pages to show around current page
          let rangeStart = Math.max(2, currentPage - Math.floor(maxVisiblePages / 2))
          const rangeEnd = Math.min(totalPages - 1, rangeStart + maxVisiblePages - 3)

          // Adjust range if current page is near the end
          if (rangeEnd === totalPages - 1) {
            rangeStart = Math.max(2, rangeEnd - maxVisiblePages + 3)
          }

          // Show ellipsis after first page if needed
          if (rangeStart > 2) {
            paginationContainer.innerHTML += `<li><span>...</span></li>`
          }

          // Show pages in range
          for (let i = rangeStart; i <= rangeEnd; i++) {
            createPageLink(i, i === currentPage)
          }

          // Show ellipsis before last page if needed
          if (rangeEnd < totalPages - 1) {
            paginationContainer.innerHTML += `<li><span>...</span></li>`
          }

          // Show last page if not already shown
          if (totalPages > 1) {
            createPageLink(totalPages, currentPage === totalPages)
          }
        }

        // Show "Next" button if not on last page
        if (currentPage < totalPages) {
          const nextItem = document.createElement("li")
          nextItem.innerHTML = `<a href="#" class="pagination-link" data-page="${currentPage + 1}">Next »</a>`
          paginationContainer.appendChild(nextItem)
        }
      }          

        // Update page and fetch data
      function updatePage(page) {
        currentSearch = searchStr.value;
        currentPage = page;
        fetchItems(currentPage, currentSearch, limit);
      }   

      // Event listener for pagination links
      paginationContainer.addEventListener('click', function(event) {
        if (event.target.classList.contains('pagination-link')) {
          event.preventDefault();
          const page = parseInt(event.target.getAttribute('data-page'), 10);
          if (!isNaN(page)) {
            updatePage(page);
          }
        }
      });      

      // Search and limit event listeners
      searchBtn.addEventListener('click', () => {
        currentSearch = searchStr.value;
        fetchItems(1, currentSearch, limit);
      });
      limitSelect.addEventListener('change', () => {
        limit = limitSelect.value;
        currentPage = 1;
        fetchItems(currentPage, currentSearch, limit);
      });

      fetchItems(currentPage, currentSearch, limit);
    });  

    // Reset items form
    $(document).on('click', '.btn-add-items', function () {
      $('#items-form')[0].reset();
      $('#items-form').removeAttr('data-items-id');
      $('#items-form input, #items-form textarea').val('');
      $('#add-edit-items-modal .modal-title').text('Add Items');
      $('#button-add-edit-items').text('Create');
    });

    // Handle items form submission
    $('#items-form').on('submit', function (e) {
      e.preventDefault();

      const id = $(this).attr('data-items-id');
      const formData = new FormData();
      formData.append('itemType', $('#itemType').val());
      formData.append('itemName', $('#itemName').val());
      formData.append('manufactureOrigin', $('#manufactureOrigin').val());
      formData.append('itemModel', $('#itemModel').val());
      formData.append('itemPrice', $('#itemPrice').val());
      formData.append('itemConfigurations', $('#itemConfigurations').val());

      const fileInput = $('#file')[0]?.files[0];
      if (fileInput) {
        formData.append('file', fileInput); // 👈 must match upload.single("file")
      }

      if (!$('#itemName').val()) {
        swal("Validation Error", "Item name is required", "error");
        return;
      }

      if (id) {
        updateItems(id, formData);
      } else {
        createItems(formData);
      }
    });

    // Create Items
    function createItems(formData) {
      $.ajax({
        url: '/rms/rms-items/create',
        type: 'POST',
        data: formData,
        processData: false,   // ✅ required
        contentType: false, 
        success: function (response) {
          if (response.status) {
            swal({
              title: response.message,
              icon: "success",
              button: "OK"
            }).then(() => {
              window.location.reload();
            });
          } else {
            swal("Error", response.message || "Failed to create item", "error");
          }
        },
        error: function (xhr) {
          swal("Error", xhr.responseJSON?.message || "Something went wrong", "error");
        }
      });
    }

    // Update Items
    function updateItems(id, formData) {
      $.ajax({
        url: `/api/rms/rms-items/update/${id}`,
        type: 'PUT',
        data: formData,
        processData: false,
        contentType: false,
        success: function (response) {
          if (response.status) {
            swal({
              title: response.message,
              icon: "success",
              button: "OK"
            }).then(() => {
              window.location.reload();
            });
          } else {
            swal("Error", response.message || "Failed to update items", "error");
          }
        },
        error: function (xhr) {
          swal("Error", xhr.responseJSON?.message || "Something went wrong", "error");
        }
      });
    }

    // Load Items for Editing
    $(document).on('click', '#editItems', function () {
      const id = $(this).attr('data-items-id');
      loadItemsForEdit(id);
    });

    function loadItemsForEdit(id) {
      $.ajax({
        url: `/api/rms/rms-items/edit/${id}`,
        type: 'GET',
        success: function (response) {
          if (response.status && response.data) {
            const items = response.data;
            $('#items-form').attr('data-items-id', id);
            $('#itemType').val(items.itemType);
            $('#itemName').val(items.itemName);
            $('#manufactureOrigin').val(items.manufactureOrigin);
            $('#itemPrice').val(items.itemPrice);
            $('#itemConfigurations').val(items.itemConfigurations);
            $('#itemModel').val(items.itemModel);
            if (items.files) {
              $('#filePreview').html(`
                <div style="margin-bottom:10px;">
                  <img src="/${items.files}" 
                       style="width:100px;height:100px;object-fit:cover;border-radius:6px;border:1px solid #ccc;" />
                </div>
              `);
            } else {
              $('#filePreview').html('<small>No file uploaded</small>');
            }

            $('#add-edit-items-modal .modal-title').text('Update Items');
            $('#button-add-edit-items').text('Update');
            $('#add-edit-items-modal').modal('show');
          } else {
            swal("Error", response.message || "Failed to load items data", "error");
          }
        },
        error: function (xhr) {
          swal("Error", xhr.responseJSON?.message || "Something went wrong", "error");
        }
      });
    }

