extends ../../../layout
block style
  link(rel='stylesheet' href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css')
  link(rel='stylesheet' href='https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css')
  style.
    .selected-row {
      background-color: #8A2061 !important;
      color: white !important;
    }

    .permission-checkbox {
      margin: 5px 0;
    }

    .role-card {
      border: 1px solid #ddd;
      border-radius: 8px;
      padding: 15px;
      margin-bottom: 15px;
      background: #f9f9f9;
    }

    .role-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 10px;
    }

    .role-name {
      font-size: 18px;
      font-weight: bold;
      color: #8A2061;
    }

    .permission-list {
      max-height: 300px;
      overflow-y: auto;
      border: 1px solid #eee;
      border-radius: 4px;
      padding: 10px;
      background: white;
    }

    .permission-item {
      display: flex;
      align-items: center;
      margin-bottom: 8px;
      padding: 5px;
      border-radius: 4px;
      background: #f8f9fa;
    }

    .permission-item:hover {
      background: #e9ecef;
    }

    .permission-checkbox {
      margin-right: 10px;
    }

    .save-btn {
      background-color: #8A2061;
      border-color: #8A2061;
      color: white;
    }

    .save-btn:hover {
      background-color: #6a1749;
      border-color: #6a1749;
    }

    .loading-spinner {
      display: inline-block;
      width: 20px;
      height: 20px;
      border: 3px solid #f3f3f3;
      border-top: 3px solid #8A2061;
      border-radius: 50%;
      animation: spin 1s linear infinite;
    }

    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

block content
  section.content-header
    h1
      | Role Permissions Management&nbsp;&nbsp;
      button.btn.btn-sm.btn-primary.btn-refresh(type='button' id='refreshBtn')
        i.fas.fa-sync-alt

    ol.breadcrumb
      li
        a(href='/dashboard')
          strong(style="color: #8A2061") Dashboard
      li
        a(href='/role-permissions')
          strong(style="color: #8A2061") Role Permissions

  section.content
    .row
      .col-md-12.col-xs-12
        .box.box-parrot
          .box-header.with-border
            .pull-left
              span.title-filter(style='display:flex;align-items:center;') Search:
                input.form-control.input-sm(type='text' placeholder='Enter role name' name='search' autocomplete='off' style='margin-left:10px' id='search')
                button.btn.btn-sm.btn-primary.btn-filter(type='submit' style='margin-left:3px' id='searchBtn')
                  span.fa.fa-filter

          .box-body#rolePermissionsContainer
            .text-center
              i.fa.fa-spinner.fa-spin(style='font-size: 24px; color: #8A2061;')
              | Loading role permissions...

block script
  script.
    document.addEventListener('DOMContentLoaded', function() {
      const container = document.getElementById('rolePermissionsContainer');
      const searchInput = document.getElementById('search');
      const searchBtn = document.getElementById('searchBtn');
      const refreshBtn = document.getElementById('refreshBtn');

      let allRoles = !{JSON.stringify(roles)};
      let allPermissions = !{JSON.stringify(permissions)};
      let rolePermissions = {};

      async function loadRolePermissions() {
        try {
          container.innerHTML = `
            <div class="text-center">
              <div class="loading-spinner"></div>
              <p>Loading role permissions...</p>
            </div>
          `;

          // Load existing role permissions
          const response = await fetch('/api/role-permissions/all');
          const data = await response.json();

          if (data.status) {
            // Group permissions by role
            rolePermissions = {};
            data.data.forEach(rp => {
              if (!rolePermissions[rp.role.roleId]) {
                rolePermissions[rp.role.roleId] = [];
              }
              rolePermissions[rp.role.roleId].push(rp.permission.permissionId);
            });

            renderRolePermissions();
          } else {
            container.innerHTML = '<div class="alert alert-danger">Failed to load role permissions</div>';
          }
        } catch (error) {
          console.error('Error loading role permissions:', error);
          container.innerHTML = '<div class="alert alert-danger">Error loading role permissions</div>';
        }
      }

      function renderRolePermissions(searchTerm = '') {
        const filteredRoles = allRoles.filter(role =>
          role.name.toLowerCase().includes(searchTerm.toLowerCase())
        );

        if (filteredRoles.length === 0) {
          container.innerHTML = '<div class="alert alert-info">No roles found matching your search.</div>';
          return;
        }

        const html = filteredRoles.map(role => {
          const rolePerms = rolePermissions[role.roleId] || [];

          return `
            <div class="role-card">
              <div class="role-header">
                <div class="role-name">${role.name}</div>
                <button class="btn btn-sm save-btn" onclick="saveRolePermissions('${role.roleId}')">
                  <i class="fas fa-save"></i> Save Changes
                </button>
              </div>
              <div class="role-description text-muted">${role.description || 'No description'}</div>
              <div class="permission-list" id="permissions-${role.roleId}">
                ${allPermissions.map(permission => {
                  const isChecked = rolePerms.includes(permission.permissionId);
                  return `
                    <div class="permission-item">
                      <input type="checkbox"
                             class="permission-checkbox"
                             id="perm-${role.roleId}-${permission.permissionId}"
                             data-role-id="${role.roleId}"
                             data-permission-id="${permission.permissionId}"
                             ${isChecked ? 'checked' : ''}>
                      <label for="perm-${role.roleId}-${permission.permissionId}" style="margin: 0; cursor: pointer; flex: 1;">
                        <strong>${permission.name}</strong>
                        ${permission.slug ? `<br><small class="text-muted">${permission.slug}</small>` : ''}
                      </label>
                    </div>
                  `;
                }).join('')}
              </div>
            </div>
          `;
        }).join('');

        container.innerHTML = html;
      }

      window.saveRolePermissions = async function(roleId) {
        const checkboxes = document.querySelectorAll(`input[data-role-id="${roleId}"]:checked`);
        const permissionIds = Array.from(checkboxes).map(cb => cb.getAttribute('data-permission-id'));

        const saveBtn = document.querySelector(`button[onclick="saveRolePermissions('${roleId}')"]`);
        const originalHtml = saveBtn.innerHTML;
        saveBtn.innerHTML = '<div class="loading-spinner"></div> Saving...';
        saveBtn.disabled = true;

        try {
          const response = await fetch('/api/role-permissions/assign', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({
              roleId: roleId,
              permissionIds: permissionIds
            })
          });

          const data = await response.json();

          if (data.status) {
            showNotification('Permissions updated successfully!', 'success');
            // Update local state
            rolePermissions[roleId] = permissionIds;
          } else {
            showNotification('Failed to update permissions: ' + data.message, 'error');
          }
        } catch (error) {
          console.error('Error saving permissions:', error);
          showNotification('Error saving permissions', 'error');
        } finally {
          saveBtn.innerHTML = originalHtml;
          saveBtn.disabled = false;
        }
      };

      function showNotification(message, type) {
        const notification = document.createElement('div');
        notification.className = `alert alert-${type === 'success' ? 'success' : 'danger'} alert-dismissible fade show`;
        notification.style.cssText = 'position: fixed; top: 20px; right: 20px; z-index: 9999; min-width: 300px;';
        notification.innerHTML = `
          ${message}
          <button type="button" class="close" data-dismiss="alert">
            <span>&times;</span>
          </button>
        `;

        document.body.appendChild(notification);

        setTimeout(() => {
          if (notification.parentNode) {
            notification.parentNode.removeChild(notification);
          }
        }, 5000);
      }

      // Event listeners
      searchBtn.addEventListener('click', () => {
        const searchTerm = searchInput.value.trim();
        renderRolePermissions(searchTerm);
      });

      searchInput.addEventListener('keyup', (e) => {
        if (e.key === 'Enter') {
          const searchTerm = searchInput.value.trim();
          renderRolePermissions(searchTerm);
        }
      });

      refreshBtn.addEventListener('click', () => {
        loadRolePermissions();
      });

      // Initial load
      loadRolePermissions();
    });