block script
  script.
    document.addEventListener('DOMContentLoaded', function() {
      const tableBody = document.getElementById('userTableBody');
      if (!tableBody) {
        console.error("Element with id 'userTableBody' not found.");
        return;
      }
      const paginationContainer = document.getElementById('paginationContainer');

      let currentPage = 1;
      let currentSearch = '';
      let limit = 10;

      async function fetchUser() {
          tableBody.innerHTML = `<tr><td colspan="12" class="text-center"><i class="fa fa-spinner fa-spin" style="font-size: 24px; color: #8A2061;"></i></td></tr>`;
          try {
            const response = await fetch(`/api/profile/all`);
            const result = await response.json();

            const user = result.data;

            if (user) {
              tableBody.innerHTML = `
                <tr style='cursor:pointer' class="table-row">
                  <td>${user.empId}</td>
                  <td>${user.username}</td>
                  <td>${user.gender}</td>
                  <td>${user.dateOfBirth}</td>
                  <td>${user.email}</td>
                  <td>${user.phone}</td>
                  <td>${user.address}</td>
                  <td>${user.role_name}</td>
                  <td>${user.isActive ? '<i class="bi bi-check-circle-fill text-success"></i>' : '<i class="bi bi-x-circle-fill text-danger"></i>'}</td>
                  <td>${user.createdAt}</td>
                  <td>${user.updatedAt}</td>
                  <td>
                    <a href="" id='editUser' class="fa fa-edit" data-user-id="${user.userId}" style="font-size: 1em;" data-toggle='modal' data-target='#add-edit-user-modal'></a>
                  </td>
                  <td>
                    <a href="#" onclick="openResetPasswordModal('${user.userId}')" class="fa fa-edit" style="font-size: 1em;"></a>
                  </td>
                </tr>
              `;
              document.querySelector('#title-filter').textContent = `Showing 1 of 1 entries`;
            } else {
              tableBody.innerHTML = `<tr><td colspan="12" class="text-center">No data found</td></tr>`;
              document.querySelector('#title-filter').textContent = 'No entries to display';
            }

          } catch (error) {
            console.error('Error fetching user:', error);
            tableBody.innerHTML = `<tr><td colspan="12" class="text-center">Error loading data</td></tr>`;
            document.querySelector('#title-filter').textContent = 'Error loading entries';
          }
        }


      function renderPagination(totalPages, currentPage) {
        paginationContainer.innerHTML = ""

        const maxVisiblePages = 5
        const firstPages = 2
        const lastPages = 2

        // Helper function to create pagination link
        const createPageLink = (page, isActive = false) => {
          const pageItem = document.createElement("li")
          if (isActive) pageItem.classList.add("active")
          pageItem.innerHTML = `<a href="#" class="pagination-link" data-page="${page}">${page}</a>`
          paginationContainer.appendChild(pageItem)
        }

        // Show "Previous" button if not on first page
        if (currentPage > 1) {
          const prevItem = document.createElement("li")
          prevItem.innerHTML = `<a href="#" class="pagination-link" data-page="${currentPage - 1}">« Previous</a>`
          paginationContainer.appendChild(prevItem)
        }

        // For small number of pages, show all pages without ellipsis
        if (totalPages <= maxVisiblePages) {
          for (let i = 1; i <= totalPages; i++) {
            createPageLink(i, i === currentPage)
          }
        } else {
          // Show first page
          createPageLink(1, currentPage === 1)

          // Calculate range of pages to show around current page
          let rangeStart = Math.max(2, currentPage - Math.floor(maxVisiblePages / 2))
          const rangeEnd = Math.min(totalPages - 1, rangeStart + maxVisiblePages - 3)

          // Adjust range if current page is near the end
          if (rangeEnd === totalPages - 1) {
            rangeStart = Math.max(2, rangeEnd - maxVisiblePages + 3)
          }

          // Show ellipsis after first page if needed
          if (rangeStart > 2) {
            paginationContainer.innerHTML += `<li><span>...</span></li>`
          }

          // Show pages in range
          for (let i = rangeStart; i <= rangeEnd; i++) {
            createPageLink(i, i === currentPage)
          }

          // Show ellipsis before last page if needed
          if (rangeEnd < totalPages - 1) {
            paginationContainer.innerHTML += `<li><span>...</span></li>`
          }

          // Show last page if not already shown
          if (totalPages > 1) {
            createPageLink(totalPages, currentPage === totalPages)
          }
        }

        // Show "Next" button if not on last page
        if (currentPage < totalPages) {
          const nextItem = document.createElement("li")
          nextItem.innerHTML = `<a href="#" class="pagination-link" data-page="${currentPage + 1}">Next »</a>`
          paginationContainer.appendChild(nextItem)
        }
      }

        // Update page and fetch data
      function updatePage(page) {
        currentPage = page;
        fetchUser(currentPage, currentSearch, limit);
      }

      // Event listener for pagination links
      paginationContainer.addEventListener('click', function(event) {
        if (event.target.classList.contains('pagination-link')) {
          event.preventDefault();
          const page = parseInt(event.target.getAttribute('data-page'), 10);
          if (!isNaN(page)) {
            updatePage(page);
          }
        }
      });


      fetchUser(currentPage, currentSearch, limit);
    });

    $(document).on('click', '.btn-add', function () {
      $('#user-form')[0].reset();
      $('#user-form').removeAttr('data-user-id');
      $('#user-form input, #user-form textarea').val('');
    });

    $('#user-form').on('submit', function (e) {
      e.preventDefault();
      const userId = $(this).attr('data-user-id');
      

      // Only validate password when creating
      if (!userId) {
        console.log(userId);
        const password = $('#password').val();
        const confirmPassword = $('#confirmPassword').val();

        if (!password || !confirmPassword) {
          swal("Error", "Password and Confirm Password are required", "error");
          return;
        }

        if (password !== confirmPassword) {
          swal("Error", "Password and Confirm Password do not match", "error");
          return;
        }
      }

      if (userId) {
        console.log('i want to update')
        updateUser(userId);
      } else {
         console.log('i want to create')
        createUser();
      }
    });

    function updateUser(userId) {
      const roleId = $('#roleId').val();
      const dateOfBirth = $('#dateOfBirth').val();
      console.log("Submitting dateOfBirth:", dateOfBirth);
      const data = {
        empId: $('#empId').val(),
        firstName: $('#firstName').val(),
        lastName: $('#lastName').val(),
        isActive: $('#isActive').is(':checked'),
        gender: $('#gender').val(),
        dateOfBirth: $('#dateOfBirth').val(),
        email: $('#email').val(),
        phone: $('#phone').val(),
        address: $('#address').val(),
        roleId: $('#roleId').val()
      };
    
      $.ajax({
        url: `/api/profile/update/${userId}`,
        type: 'PUT',
        contentType: 'application/json',
        data: JSON.stringify(data),
        success: function (response) {
          if (response.status) {
            swal({
              title: response.message,
              icon: "success",
              closeOnClickOutside: false,
              button: 'OK'
            }).then(() => {
              window.location.reload(); // Reload page on success
            });
          } else {
            swal("Error", response.message || "Failed to update user record", "error");
          }
        }
      });
    }

    $(document).on('click', '#editUser', function () {
      const userId = $(this).attr('data-user-id');
      console.log(userId)
      console.log("userId from data attr:", userId);
      loadUserForEdit(userId);
    });

    function loadUserForEdit(userId) {
      console.log("[Frontend] loadUserForEdit() called with:", userId);
      $.ajax({
        url: `/api/profile/edit/${userId}`,
        type: 'GET',
        success: function (response) {
          if (response.status) {
            $('#user-form').attr('data-user-id', response.data.userId);
            $('#empId').val(response.data.empId);
            $('#firstName').val(response.data.firstName);
            $('#lastName').val(response.data.lastName);
            $('#isActive').prop('checked', response.data.isActive === true);
            $('#gender').val(response.data.gender).trigger('change');
            $('#dateOfBirth').val(formatDateForInput(response.data.dateOfBirth));
            $('#email').val(response.data.email);
            $('#phone').val(response.data.phone);
            $('#address').val(response.data.address);
            $('#roleId').val(String(response.data.roleId)).trigger('change');

            $('#add-edit-user-modal.modal-title').text('Update User');
            $('#button-add-edit-user').text('Update');
            // 🔸 Show reset password button
            $('#password').closest('.form-group').hide();
            $('#confirmPassword').closest('.form-group').hide();
          } else {
            swal("Error", response.message || "Failed to load coupon", "error");
          }
        }
      });
    }

    function createUser(userId) {
      const data = {
        empId: $('#empId').val(),
        firstName: $('#firstName').val(),
        lastName: $('#lastName').val(),
        isActive: $('#isActive').is(':checked'),
        gender: $('#gender').val(),
        dateOfBirth: $('#dateOfBirth').val(),
        email: $('#email').val(),
        phone: $('#phone').val(),
        address: $('#address').val(),
        roleId: $('#roleId').val(),
        password: $('#password').val(),
        confirmPassword: $('#confirmPassword').val()
      };
    
      $.ajax({
        url: `/signup`,
        type: 'Post',
        contentType: 'application/json',
        data: JSON.stringify(data),
        success: function (response) {
          if (response.status) {
            swal({
              title: response.message,
              icon: "success",
              closeOnClickOutside: false,
              button: 'OK'
            }).then(() => {
              window.location.reload(); // Reload page on success
            });
          } else {
            swal("Error", response.message || "Failed to Create user record", "error");
          }
        }
      });
    }    

    $('#fetchEmployeeBtn').on('click', async function () {
      const empId = $('#empId').val().trim();
      if (!empId) {
        alert('Please enter an Employee ID');
        return;
      }

      try {
        const response = await fetch('/api/users/check-empId', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ empId })
        });

        const result = await response.json();

        if (!result.status || !result.data) {
          alert('No employee data found.');
          return;
        }

        const data = result.data;
        const $modal = $('#add-edit-user-modal');
        

        // Populate form fields with API data
        $('#firstName').val(data.firstName || '');
        $('#lastName').val(data.lastName || '');
        $('#phone').val(data.mobileNo || '');
        $('#email').val(data.email || '');
        const dobInput = document.getElementById("dateOfBirth");
        const dob = new Date(data.dob);
        dobInput.value = dob.toISOString().split('T')[0];
        let genderSelect = document.getElementById('gender')
        const gender = data.gender;

        if (gender === 'Male') {
          genderSelect.value = 'M';
        } else if (gender === 'Female') {
          genderSelect.value = 'F';
        } else {
          genderSelect.value = 'M';
        }        

        if ($.fn.select2) {
          $(genderSelect).trigger('change').select2();
        }

        // If status comes from API, you can also update isActive
        if (data.status !== undefined) {
          $('#isActive').prop('checked', data.status);
        }
      } catch (err) {
        console.error(err);
        alert('Error fetching employee data');
      }
    });

    function openResetPasswordModal(userId) {
      $('#resetUserId').val(userId); // ✅ store the user ID
      $('#resetPasswordModal').modal('show');
    }

    function formatDateForInput(dateStr) {
      if (!dateStr) return '';
      const date = new Date(dateStr);
      return date.toISOString().split('T')[0];  // returns YYYY-MM-DD
    }

    $('#reset-password-form').on('submit', function (e) {
      e.preventDefault();
      const userId = $('#resetUserId').val();
      const newPassword = $('#newPassword').val().trim();
      const cPassword = $('#cPassword').val().trim();

      if (newPassword !== cPassword) {
        return swal("Mismatch", "New password and confirm password must match", "warning");
      }

      $.ajax({
        url: '/api/profile/reset-password',
        type: 'POST',
        contentType: 'application/json',
        data: JSON.stringify({ userId, newPassword }),
        success: function (res) {
          if (res.status) {
            $('#resetPasswordModal').modal('hide');
            swal("Success", res.message, "success");
          } else {
            swal("Error", res.message, "error");
          }
        },
        error: function () {
          swal("Error", "Something went wrong", "error");
        }
      });
    });


        