block script
  script.
    document.addEventListener('DOMContentLoaded', function() {
      const tableBody = document.getElementById('permissionTableBody');
      if (!tableBody) {
        console.error("Element with id 'permissionTableBody' not found.");
        return;
      }
      const paginationContainer = document.getElementById('paginationContainer');
      const searchStr = document.getElementById('search');
      const searchBtn = document.getElementById('searchBtn');
      const limitSelect = document.getElementById('limitSelect');

      let currentPage = 1;
      let currentSearch = '';
      let limit = limitSelect.value;

      async function fetchPermission(page = 1, search = '', limit = 10) {
        tableBody.innerHTML = `<tr><td colspan="7" class="text-center"><i class="fa fa-spinner fa-spin" style="font-size: 24px; color: #8A2061;"></i></td></tr>`;
        try {
          const response = await fetch(`/api/permissions/all?page=${page}&search=${search}&limit=${limit}`);
          const data = await response.json();

          if (data?.data?.length > 0) {
            tableBody.innerHTML = data.data.map(permission => {
            return `
              <tr style='cursor:pointer' class="table-row">
                <td>${permission.permissionId}</td>
                <td>${permission.name}</td>
                <td>${permission.slug}</td>
                <td>
                  ${permission.isActive 
                    ? '<i class="bi bi-check-circle-fill text-success"></i>' 
                    : '<i class="bi bi-x-circle-fill text-danger"></i>'}
                </td>
                <td>${permission.createdAt}</td>
                <td>${permission.updatedAt}</td>
                <td>
                  <a href="" id='editPermission' class="fa fa-edit" data-permission-id="${permission.permissionId}" style="font-size: 1em;" data-toggle='modal' data-target='#add-edit-permission-modal'></a>
                </td>
              </tr>
          `;
          }).join('');

          const totalRecords = data.totalRecords;
          const startRecord = (currentPage - 1) * limit + 1;
          const endRecord = Math.min(currentPage * limit, totalRecords);

          document.querySelector('#title-filter').textContent = `Showing ${startRecord} to ${endRecord} of ${totalRecords} entries`;

          } else {
            tableBody.innerHTML = `<tr><td colspan="7" class="text-center">No data found</td></tr>`;
            document.querySelector('#title-filter').textContent = 'No entries to display';
            return;
          }

          // Generate pagination buttons
          const totalPages = Math.ceil(data.totalRecords / limit);
          renderPagination(totalPages, currentPage);

        } catch (error) {
          console.error('Error fetching reports:', error);
          tableBody.innerHTML = `<tr><td colspan="7" class="text-center">Error loading data</td></tr>`;
          document.querySelector('#title-filter').textContent = 'Error loading entries';
        }
      }

      function renderPagination(totalPages, currentPage) {
        paginationContainer.innerHTML = ""

        const maxVisiblePages = 5
        const firstPages = 2
        const lastPages = 2

        // Helper function to create pagination link
        const createPageLink = (page, isActive = false) => {
          const pageItem = document.createElement("li")
          if (isActive) pageItem.classList.add("active")
          pageItem.innerHTML = `<a href="#" class="pagination-link" data-page="${page}">${page}</a>`
          paginationContainer.appendChild(pageItem)
        }

        // Show "Previous" button if not on first page
        if (currentPage > 1) {
          const prevItem = document.createElement("li")
          prevItem.innerHTML = `<a href="#" class="pagination-link" data-page="${currentPage - 1}">« Previous</a>`
          paginationContainer.appendChild(prevItem)
        }

        // For small number of pages, show all pages without ellipsis
        if (totalPages <= maxVisiblePages) {
          for (let i = 1; i <= totalPages; i++) {
            createPageLink(i, i === currentPage)
          }
        } else {
          // Show first page
          createPageLink(1, currentPage === 1)

          // Calculate range of pages to show around current page
          let rangeStart = Math.max(2, currentPage - Math.floor(maxVisiblePages / 2))
          const rangeEnd = Math.min(totalPages - 1, rangeStart + maxVisiblePages - 3)

          // Adjust range if current page is near the end
          if (rangeEnd === totalPages - 1) {
            rangeStart = Math.max(2, rangeEnd - maxVisiblePages + 3)
          }

          // Show ellipsis after first page if needed
          if (rangeStart > 2) {
            paginationContainer.innerHTML += `<li><span>...</span></li>`
          }

          // Show pages in range
          for (let i = rangeStart; i <= rangeEnd; i++) {
            createPageLink(i, i === currentPage)
          }

          // Show ellipsis before last page if needed
          if (rangeEnd < totalPages - 1) {
            paginationContainer.innerHTML += `<li><span>...</span></li>`
          }

          // Show last page if not already shown
          if (totalPages > 1) {
            createPageLink(totalPages, currentPage === totalPages)
          }
        }

        // Show "Next" button if not on last page
        if (currentPage < totalPages) {
          const nextItem = document.createElement("li")
          nextItem.innerHTML = `<a href="#" class="pagination-link" data-page="${currentPage + 1}">Next »</a>`
          paginationContainer.appendChild(nextItem)
        }
      }

        // Update page and fetch data
      function updatePage(page) {
        currentSearch = searchStr.value;
        currentPage = page;
        fetchPermission(currentPage, currentSearch, limit);
      }

      // Event listener for pagination links
      paginationContainer.addEventListener('click', function(event) {
        if (event.target.classList.contains('pagination-link')) {
          event.preventDefault();
          const page = parseInt(event.target.getAttribute('data-page'), 10);
          if (!isNaN(page)) {
            updatePage(page);
          }
        }
      });


      // Search and limit event listeners
      searchBtn.addEventListener('click', () => {
        currentSearch = searchStr.value;
        fetchPermission(1, currentSearch, limit);
      });
      limitSelect.addEventListener('change', () => {
        limit = limitSelect.value;
        currentPage = 1;
        fetchPermission(currentPage, currentSearch, limit);
      });

      fetchPermission(currentPage, currentSearch, limit);
    });

    $(document).on('click', '.btn-add', function () {
      $('#permission-form')[0].reset();
      $('#permission-form').removeAttr('data-permission-id');
      $('#permission-form input, #permission-form textarea').val('');
    });

    $('#permission-form').on('submit', function (e) {
      e.preventDefault();
      const permissionId = $(this).attr('data-permission-id');

      if (permissionId) {
        updatePermission(permissionId);
      } else {
        createPermission();
      }
    });

    function updatePermission(permissionId) {
      const data = {
        name: $('#name').val(),
        slug: $('#slug').val(),
        isActive: $('#isActive').is(':checked')
      };
    
      $.ajax({
        url: `/api/permissions/update/${permissionId}`,
        type: 'PUT',
        contentType: 'application/json',
        data: JSON.stringify(data),
        success: function (response) {
          if (response.status) {
            swal({
              title: response.message,
              icon: "success",
              closeOnClickOutside: false,
              button: 'OK'
            }).then(() => {
              window.location.reload(); // Reload page on success
            });
          } else {
            swal("Error", response.message || "Failed to update permission record", "error");
          }
        }
      });
    }

    $(document).on('click', '#editPermission', function () {
      const permissionId = $(this).attr('data-permission-id');
      loadPermissionForEdit(permissionId);
    });

    function loadPermissionForEdit(permissionId) {
      $.ajax({
        url: `/api/permissions/edit/${permissionId}`,
        type: 'GET',
        success: function (response) {
          if (response.status) {
            $('#permission-form').attr('data-permission-id', response.data.permissionId);
            $('#name').val(response.data.name);
            $('#slug').val(response.data.slug);
            $('#isActive').prop('checked', response.data.isActive === true);

            $('#add-edit-permission-modal.modal-title').text('Update Permission');
            $('#button-add-edit-permission').text('Update');
          } else {
            swal("Error", response.message || "Failed to load coupon", "error");
          }
        }
      });
    }

    function createPermission(permissionId) {
      const data = {
        name: $('#name').val(),
        slug: $('#slug').val(),
        isActive: $('#isActive').is(':checked')
      };
    
      $.ajax({
        url: `/permission`,
        type: 'Post',
        contentType: 'application/json',
        data: JSON.stringify(data),
        success: function (response) {
          if (response.status) {
            swal({
              title: response.message,
              icon: "success",
              closeOnClickOutside: false,
              button: 'OK'
            }).then(() => {
              window.location.reload(); // Reload page on success
            });
          } else {
            swal("Error", response.message || "Failed to Create Permission record", "error");
          }
        }
      });
    }

    function generateSlug(name) {
      return name
        .toLowerCase()
        .trim()
        .replace(/[^a-z0-9\s-]/g, '')
        .replace(/\s+/g, '-')
        .replace(/-+/g, '-');    
    }


    $(document).on('keyup blur', '#name', function () {
      const nameValue = $(this).val();
      const slugValue = generateSlug(nameValue);
      $('#slug').val(slugValue);
    });