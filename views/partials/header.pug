              li.dropdown.user.user-menu
                a.dropdown-toggle(href='#', data-toggle='dropdown')
                  img.user-image(
                    src= user.files ? `/${user.files}` : '/dist/img/rms-logo.png',
                    alt='User Image'
                  )
                  span.hidden-xs #{user.username || 'User'}

                ul.dropdown-menu(style="border-radius:12px; overflow:hidden; padding:0; width:260px;")

                  // USER HEADER CARD
                  li.user-header(style="background:linear-gradient(135deg,#4facfe,#00f2fe); padding:20px; text-align:center; color:#fff;")

                    img(
                      src= user.files ? `/${user.files}` : '/dist/img/rms-logo.png',
                      style="width:70px;height:70px;border-radius:50%;object-fit:cover;border:3px solid #fff;"
                    )

                    p(style="margin-top:10px; font-weight:600;")
                      | #{user.username || 'User'}
                    
                    small(style="display:block;")
                      | Employee ID: #{user.empId}
                    
                    small(style="display:block;")
                      | Role: #{user.roleName}

                  // BODY
                  li.user-body(style="padding:15px; text-align:center;")

                    if (user.roleName || '').toLowerCase() === 'superadmin'
                      .row
                        .col-xs-4
                          a(href='/signup', style="font-size:12px; display:block; color:#333;") Users
                        .col-xs-4
                          a(href='/roles', style="font-size:12px; display:block; color:#333;") Roles
                        .col-xs-4
                          a(href='/permission', style="font-size:12px; display:block; color:#333;") Permissions
                    else
                      span.label(
                        style="background:#6f42c1; padding:6px 12px; border-radius:20px; color:#fff; font-size:12px;"
                      ) #{user.roleName}

                  // FOOTER
                  li.user-footer(style="display:flex; justify-content:space-between; padding:10px; background:#f7f7f7;")

                    a.btn.btn-default.btn-sm(href='/profile')
                      i.fa.fa-user
                      |  Profile

                    a.btn.btn-danger.btn-sm(href='/logout')
                      i.fa.fa-sign-out
                      |  Logout
              