        $(document).ready(function() {
          // Sidebar search
          $('#sidebarSearch').on('keyup', function() {
            const query = $(this).val().toLowerCase();
      
            $('#sidebarMenu > li').each(function() {
              const li = $(this);
              let match = false;
      
              li.find('a').each(function() {
                if ($(this).text().toLowerCase().indexOf(query) !== -1) {
                  match = true;
                  return false; // break
                }
              });
      
              if (match) {
                li.show();
                li.parents('li').show(); // show parent tree if child matches
              } else {
                li.hide();
              }
            });
          });
      
          // Keep your existing JS here, e.g., tooltip init
          $("body").tooltip({ selector: '[data-toggle=tooltip]' });
        });


