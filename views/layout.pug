       input[type="checkbox"] {
       accent-color: #580db4;
      }
      .pagination > .active > a, .pagination > .active > span, .pagination > .active > span:focus, .pagination > .active > span:hover {
        z-index: 3;
        color: #fff;
        cursor: default;
        background-color: #580db4 !important;
        border-color: #580db4 !important;
      }
      .table > tbody > tr > td, .table > tbody > tr > th, .table > tfoot > tr > td, .table > tfoot > tr > th, .table > thead > tr > td, .table > thead > tr > th {
        padding: 5px;
        line-height: 1.42857143;
        vertical-align: top;
        border-top: 1px solid #ddd;
      }
      .btn-primary.focus, .btn-primary:focus {
        color: #fff;
        background-color: #580db4 !important;
        border-color: #580db4 !important;
      }
      a.fa-eye, .fa-envelope, .fa-edit, .fa-info-circle {
        background-color: #580db4;
        padding: 8px;
        border-radius: 4px; /* Slightly rounded corners */
        color: white;
        width: 18px; /* Ensures the button is small and square */
        height: 18px; /* Ensures the button is small and square */
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1em;
      }
      .input-sm {
        height: 30px;
        padding: 5px 10px;
        font-size: 11px;
        line-height: 1.5;
      }
    block style

