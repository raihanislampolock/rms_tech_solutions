#imagingReportModal.modal.fade(role='dialog', aria-labelledby='imagingReportModalLabel', aria-hidden='true')
  .modal-dialog.modal-lg(role='document')
    .modal-content
      .modal-header
        button.close(type='button', data-dismiss='modal', aria-label='Close')
          span(aria-hidden='true') &times;
        h4#imagingReportModalLabel.modal-title Imaging Report Details
      .modal-body(style='max-height: 70vh; overflow-y: auto;')
        #imaging-report-content
      .modal-footer
        button.btn.btn-secondary(type='button', data-dismiss='modal') Close
