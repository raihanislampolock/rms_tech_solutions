extends ../layout

include ../partials/dashboard-selector

block content
  section.content-header
    h1
      | Medical Service Admin Dashboard
    ol.breadcrumb
      li
        a(href='/dashboard')
          i.fa.fa-dashboard
          |  Dashboard
      li.active Medical Service Admin Dashboard

  section.content
    //- Dashboard Selector
    +dashboardSelector(user.roleName)
    
    .row
      .col-md-4.col-sm-6.col-xs-12
        .info-box
          span.info-box-icon.bg-aqua
            i.fa.fa-user-circle-o 
          .info-box-content
            span.info-box-text Total Users
            span.info-box-number #{stats.total_users}
            .progress
              .progress-bar.progress-bar-aqua(style='width: 100%')

      .col-md-4.col-sm-6.col-xs-12
        .info-box(data-toggle='modal', data-target='#imagingReportModal', style='cursor: pointer;')
          span.info-box-icon.bg-red
            i.fa.fa-paper-plane 
          .info-box-content
            span.info-box-text Total Imaging Reports
            span.info-box-number #{stats.total_ImgReports}
            .progress
              .progress-bar.bg-red(style='width: 100%')

      .col-md-4.col-sm-6.col-xs-12
        .info-box(data-toggle='modal', data-target='#todayimagingReportModal', style='cursor: pointer;')
          span.info-box-icon.bg-orange
            i.fa.fa-share-square
          .info-box-content
            span.info-box-text Today's Imaging Reports
            span.info-box-number #{stats.today_ImgReports}
            .progress
              .progress-bar.bg-orange(style='width: 100%')

      .col-md-4.col-sm-6.col-xs-12
        .info-box(data-toggle='modal', data-target='#prescriptionReportModal', style='cursor: pointer;')
          span.info-box-icon.bg-parrot
            i.fa.fa-medkit(style='color: white')
          .info-box-content
            span.info-box-text Total Prescriptions
            span.info-box-number #{stats.total_prescriptions}
            .progress
              .progress-bar.progress-bar-parrot(style='width: 100%')

      .col-md-4.col-sm-6.col-xs-12
        .info-box(data-toggle='modal', data-target='#todayprescriptionReportModal', style='cursor: pointer;')
          span.info-box-icon.bg-parrot
            i.fa.fa-plus-square(style='color: white')
          .info-box-content
            span.info-box-text Today's Prescriptions
            span.info-box-number #{stats.today_prescriptions}
            .progress
              .progress-bar.progress-bar-parrot(style='width: 100%')

    .row
      .col-md-12
        .box.box-parrot
          .box-header
            h3.box-title Quick Link Button for Medical Service Admin

      .col-md-4.col-sm-6.col-xs-12
        a(href='/medical-service/radiology' style='text-decoration:none; color:inherit;')
          .info-box(style='cursor: pointer;')
            span.info-box-icon(style="background-color: #15656dff;")
              <i class="fa fa-x-ray" style="font-size:48px;color:white"></i>
            .info-box-content
              span.info-box-text Admin X-Ray Tracker
              span.info-box-text(style="font-size:14px; font-weight:600;") Dashboard
              .progress
                .progress-bar.bg-red(style='width: 100%')
              span.info-box-text(style='font-weight: bold;') 

      .col-md-4.col-sm-6.col-xs-12
        a(href='/medical-service/send-imaging' style='text-decoration:none; color:inherit;')
          .info-box(style='cursor: pointer;')
            span.info-box-icon(style="background-color: #15656dff;")
              <i class="fa fa-images" style="font-size:48px;color:white"></i>
            .info-box-content
              span.info-box-text Admin Imaging Report
              span.info-box-text(style="font-size:14px; font-weight:600;") Dashboard
              .progress
                .progress-bar.bg-red(style='width: 100%')
              span.info-box-text(style='font-weight: bold;') 

      .col-md-4.col-sm-6.col-xs-12
        a(href='/medical-service/send-prescription' style='text-decoration:none; color:inherit;')
          .info-box(style='cursor: pointer;')
            span.info-box-icon(style="background-color: #15656dff;")
              <i class="fa fa-file-prescription" style="font-size:48px;color:white"></i>
            .info-box-content
              span.info-box-text Admin Prescription Report
              span.info-box-text(style="font-size:14px; font-weight:600;") Dashboard
              .progress
                .progress-bar.bg-red(style='width: 100%')
              span.info-box-text(style='font-weight: bold;')  

      .col-md-4.col-sm-6.col-xs-12
        a(href='medical-service/doctor-commission' style='text-decoration:none; color:inherit;')
          .info-box(style='cursor: pointer;')
            span.info-box-icon(style="background-color: #15656dff;")
              <i class="fa fa-money-bill-trend-up" style="font-size:48px;color:white"></i>
            .info-box-content
              span.info-box-text Admin Doctor Commission
              span.info-box-text(style="font-size:14px; font-weight:600;") Data Dashboard
              .progress
                .progress-bar.bg-red(style='width: 100%')
              span.info-box-text(style='font-weight: bold;')  

    include ./imaging.create.pug
    include ./prescription.create.pug
    include ./today.imaging.create.pug
    include ./today.prescription.create.pug

