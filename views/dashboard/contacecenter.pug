extends ../layout

block style
  style.
    .neon-box {
      background: #ffffffff;
      border-radius: 8px;
      box-shadow:
        0 0 0 0px #797777ff,
        0 0 5px rgba(255, 255, 255, 0.8),
        0 0 24px rgba(100, 96, 96, 0.6);
      transition: all 0.3s ease;
    }

    .neon-box:hover {
      box-shadow:
        
        0 0 20px rgba(138, 32, 97, 1),
        0 0 40px rgba(0, 0, 0, 0.9);
      transform: translateY(-4px);
    }

    .neon-icon {
      background: #000 !important;
      box-shadow:
        inset 0 0 8px rgba(138, 32, 97, 1),
        0 0 10px rgba(138, 32, 97, 1);
    }

